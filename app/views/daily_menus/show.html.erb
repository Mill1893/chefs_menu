<% content_for :title, @daily_menu.date %>
<div style="max-width:600px;margin:2rem auto;padding:2rem;background:#fff;border-radius:8px;box-shadow:0 2px 8px #eee;">
  <h2 style="margin-top:0;">Daily Menu Details</h2>
  <table style="width:100%;margin-bottom:1.5em;">
    <tr><th style="text-align:left;padding-right:1em;">Date:</th><td><%= @daily_menu.date %></td></tr>
  </table>
  <div style="margin-bottom:1.5em;">
    <%= link_to 'Add Items from Menu', menu_items_path(add_to_daily_menu: @daily_menu.id), class: 'btn', style: 'background:#007bff;color:#fff;padding:0.5em 1.5em;border:none;border-radius:4px;text-decoration:none;' %>
    <%= link_to 'Add Custom Item', new_daily_menu_item_path(daily_menu_id: @daily_menu.id), class: 'btn', style: 'background:#28a745;color:#fff;padding:0.5em 1.5em;border:none;border-radius:4px;text-decoration:none;margin-left:1em;' %>
  </div>
  <div style="display:flex;gap:1em;">
    <%= link_to "Edit", edit_daily_menu_path(@daily_menu), class: 'btn', style: 'background:#222;color:#fff;padding:0.5em 1.5em;border:none;border-radius:4px;text-decoration:none;' %>
    <%= button_to "Delete", @daily_menu, method: :delete, data: { confirm: 'Are you sure?' }, class: 'btn', style: 'background:#b94a48;color:#fff;padding:0.5em 1.5em;border:none;border-radius:4px;' %>
    <%= link_to "Back", daily_menus_path, style: 'margin-left:auto;text-decoration:none;color:#222;' %>
  </div>
</div>
