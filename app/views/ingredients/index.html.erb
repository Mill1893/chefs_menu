<% content_for :title, "Ingredients" %>
<h1 style="margin-bottom:1.5rem;">Ingredients</h1>
<div style="overflow-x:auto;">
  <table style="width:100%;border-collapse:collapse;background:#fff;box-shadow:0 2px 8px #eee;">
    <thead>
      <tr style="background:#f5f5f5;">
        <th style="padding:0.7em 1em;text-align:left;">Name</th>
        <th style="padding:0.7em 1em;text-align:left;">Quantity</th>
        <th style="padding:0.7em 1em;text-align:left;">Menu Item</th>
        <th style="padding:0.7em 1em;text-align:left;">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @ingredients.each do |ingredient| %>
        <tr>
          <td style="padding:0.7em 1em;"> <%= ingredient.name %> </td>
          <td style="padding:0.7em 1em;"> <%= ingredient.quantity %> </td>
          <td style="padding:0.7em 1em;"> <%= ingredient.menu_item&.name %> </td>
          <td style="padding:0.7em 1em;">
            <%= link_to 'Show', ingredient, style: 'margin-right:0.5em;' %>
            <%= link_to 'Edit', edit_ingredient_path(ingredient), style: 'margin-right:0.5em;' %>
            <%= link_to 'Delete', ingredient, method: :delete, data: { confirm: 'Are you sure?' }, style: 'color:#b94a48;' %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
<div style="margin-top:2em;">
  <%= link_to "New Ingredient", new_ingredient_path, class: 'btn', style: 'background:#222;color:#fff;padding:0.7em 2em;border:none;border-radius:4px;font-size:1.1em;text-decoration:none;' %>
</div>
