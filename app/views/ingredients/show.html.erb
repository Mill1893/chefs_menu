<% content_for :title, @ingredient.name %>
<div style="max-width:600px;margin:2rem auto;padding:2rem;background:#fff;border-radius:8px;box-shadow:0 2px 8px #eee;">
  <h2 style="margin-top:0;">Ingredient Details</h2>
  <table style="width:100%;margin-bottom:1.5em;">
    <tr><th style="text-align:left;padding-right:1em;">Name:</th><td><%= @ingredient.name %></td></tr>
    <tr><th style="text-align:left;padding-right:1em;">Quantity:</th><td><%= @ingredient.quantity %></td></tr>
    <tr><th style="text-align:left;padding-right:1em;">Menu Item:</th><td><%= @ingredient.menu_item&.name %></td></tr>
  </table>
  <div style="display:flex;gap:1em;">
    <%= link_to "Edit", edit_ingredient_path(@ingredient), class: 'btn', style: 'background:#222;color:#fff;padding:0.5em 1.5em;border:none;border-radius:4px;text-decoration:none;' %>
    <%= button_to "Delete", @ingredient, method: :delete, data: { confirm: 'Are you sure?' }, class: 'btn', style: 'background:#b94a48;color:#fff;padding:0.5em 1.5em;border:none;border-radius:4px;' %>
    <%= link_to "Back", ingredients_path, style: 'margin-left:auto;text-decoration:none;color:#222;' %>
  </div>
</div>
