<% content_for :title, "Daily Menu Items" %>
<h1 style="margin-bottom:1.5rem;">Daily Menu Items</h1>
<div style="overflow-x:auto;">
  <table style="width:100%;border-collapse:collapse;background:#fff;box-shadow:0 2px 8px #eee;">
    <thead>
      <tr style="background:#f5f5f5;">
        <th style="padding:0.7em 1em;text-align:left;">Name</th>
        <th style="padding:0.7em 1em;text-align:left;">Category</th>
        <th style="padding:0.7em 1em;text-align:left;">Description</th>
        <th style="padding:0.7em 1em;text-align:left;">Daily Menu</th>
        <th style="padding:0.7em 1em;text-align:left;">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @daily_menu_items.each do |daily_menu_item| %>
        <tr>
          <td style="padding:0.7em 1em;"> <%= daily_menu_item.name %> </td>
          <td style="padding:0.7em 1em;"> <%= daily_menu_item.category %> </td>
          <td style="padding:0.7em 1em;"> <%= truncate(daily_menu_item.description, length: 60) %> </td>
          <td style="padding:0.7em 1em;"> <%= daily_menu_item.daily_menu&.date %> </td>
          <td style="padding:0.7em 1em;">
            <%= link_to 'Show', daily_menu_item, style: 'margin-right:0.5em;' %>
            <%= link_to 'Edit', edit_daily_menu_item_path(daily_menu_item), style: 'margin-right:0.5em;' %>
            <%= link_to 'Delete', daily_menu_item, method: :delete, data: { confirm: 'Are you sure?' }, style: 'color:#b94a48;' %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
<div style="margin-top:2em;">
  <%= link_to "New Daily Menu Item", new_daily_menu_item_path, class: 'btn', style: 'background:#222;color:#fff;padding:0.7em 2em;border:none;border-radius:4px;font-size:1.1em;text-decoration:none;' %>
</div>
