<% if notice %>
  <div style="background:#d4edda;color:#155724;padding:1em;margin-bottom:1.5em;border-radius:6px;border:1px solid #c3e6cb;max-width:700px;">
    <%= notice %>
  </div>
<% end %>
<% content_for :title, "Menu Items" %>
<h1 style="margin-bottom:1.5rem;">Menu Items</h1>
<div style="overflow-x:auto;">
  <table style="width:100%;border-collapse:collapse;background:#fff;box-shadow:0 2px 8px #eee;">
    <thead>
      <tr style="background:#f5f5f5;">
        <th style="padding:0.7em 1em;text-align:left;">Name</th>
        <th style="padding:0.7em 1em;text-align:left;">Category</th>
        <th style="padding:0.7em 1em;text-align:left;">Description</th>
        <th style="padding:0.7em 1em;text-align:left;">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @menu_items.each do |menu_item| %>
        <tr>
          <td style="padding:0.7em 1em;"> <%= menu_item.name %> </td>
          <td style="padding:0.7em 1em;"> <%= menu_item.category %> </td>
          <td style="padding:0.7em 1em;"> <%= truncate(menu_item.description, length: 60) %> </td>
          <td style="padding:0.7em 1em;">
            <%= link_to 'Show', menu_item, style: 'margin-right:0.5em;' %>
            <%= link_to 'Edit', edit_menu_item_path(menu_item), style: 'margin-right:0.5em;' %>
            <%= link_to 'Delete', menu_item, method: :delete, data: { confirm: 'Are you sure?' }, style: 'color:#b94a48;margin-right:0.5em;' %>
            <% if @add_to_daily_menu && @daily_menu %>
              <%= button_to 'Add to Daily Menu', add_to_daily_menu_menu_item_path(menu_item, daily_menu_id: @daily_menu.id), method: :post, class: 'btn', style: 'background:#28a745;color:#fff;padding:0.3em 1em;border:none;border-radius:4px;font-size:0.95em;margin-left:0.5em;' %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
<div style="margin-top:2em;">
  <%= link_to "New Menu Item", new_menu_item_path, class: 'btn', style: 'background:#222;color:#fff;padding:0.7em 2em;border:none;border-radius:4px;font-size:1.1em;text-decoration:none;' %>
</div>
