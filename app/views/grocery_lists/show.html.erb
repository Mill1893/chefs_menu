
<% daily_menu = @grocery_list.daily_menu %>
<% items = daily_menu.daily_menu_items.includes(:daily_menu) %>
<% # Gather all ingredients from the original menu items for each daily menu item %>
<% ingredient_hash = Hash.new { |h, k| h[k] = [] } %>
<% items.each do |item| %>
  <% menu_item = MenuItem.find_by(name: item.name, category: item.category) %>
  <% if menu_item %>
    <% menu_item.ingredients.each do |ingredient| %>
      <% ingredient_hash[ingredient.menu_item.category] << ingredient %>
    <% end %>
  <% end %>
<% end %>

<h2 style="margin-top:2em;">Grocery List for <%= daily_menu.date %></h2>
<% if ingredient_hash.any? %>
  <% ingredient_hash.each do |category, ingredients| %>
    <h3 style="margin-top:1.5em;color:#007bff;">Category: <%= category %></h3>
    <ul style="font-size:1.1em;">
      <% ingredients.each do |ingredient| %>
        <li><%= ingredient.quantity %> <%= ingredient.name %> <span style="color:#888;">(for <%= ingredient.menu_item.name %>)</span></li>
      <% end %>
    </ul>
  <% end %>
<% else %>
  <p>No ingredients found for this daily menu.</p>
<% end %>

<div style="margin-top:2em;">
  <%= link_to "Download PDF", pdf_grocery_list_path(@grocery_list), class: 'btn', style: 'background:#007bff;color:#fff;padding:0.5em 1.5em;border:none;border-radius:4px;text-decoration:none;margin-right:1em;' %>
  <%= link_to "Edit this grocery list", edit_grocery_list_path(@grocery_list) %> |
  <%= link_to "Back to grocery lists", grocery_lists_path %>
  <%= button_to "Destroy this grocery list", @grocery_list, method: :delete %>
</div>
